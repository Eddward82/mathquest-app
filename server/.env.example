# Copy this file to server/.env and fill in your key.
# server/.env is gitignored — never commit real API keys.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Shared secret the mobile app must send in the `x-app-key` header.
# Must match EXPO_PUBLIC_APP_PROXY_KEY in the app's build env (eas.json / .env).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Leave unset to disable the check (e.g. for quick local testing).
APP_PROXY_KEY=

# Optional: change the port the proxy listens on (default 3000)
# PORT=3000
