# ─── Firebase Configuration ───────────────────────────────────────────────────
# With @react-native-firebase, credentials live in native config files:
#   Android → android/app/google-services.json
#   iOS     → ios/GoogleService-Info.plist
#
# Download both from the Firebase console and place them in the correct folders.
# You do NOT need to put Firebase keys here — the native SDK reads them directly.

# ─── API URL for your backend (AI proxy server) ───────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Shared secret sent to the AI proxy (x-app-key header) ────────────────────
# Must match APP_PROXY_KEY in server/.env. This value is bundled into the app,
# so it only deters drive-by abuse of the public endpoint — it is not strong
# auth. For local dev, set it here. For production it is stored as an EAS env
# var (kept out of git) rather than in eas.json, e.g.:
#   eas env:create --environment production \
#     --name EXPO_PUBLIC_APP_PROXY_KEY --value "<secret>" --visibility sensitive
EXPO_PUBLIC_APP_PROXY_KEY=

# ─── OpenAI API Key (server-side ONLY — never put this in the Expo app) ───────
# Add this to server/.env (create it — it is gitignored)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
